<apex:page controller="DocGenAuthenticatorController" showHeader="false" sidebar="false"
           standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false" docType="html-5.0">
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document Authenticator</title>
    <apex:slds />
    <style>
        * { box-sizing: border-box; }
        body {
            background: #f3f2f2;
            font-family: 'Salesforce Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0; padding: 0; color: #181818;
        }
        .page-wrapper {
            min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1rem;
        }
        .verify-card {
            max-width: 640px; width: 100%; background: #fff; border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.1); padding: 2rem;
        }
        .verify-card h2 { font-size: 1.25rem; font-weight: 700; margin: 0 0 0.5rem 0; text-align: center; }
        .verify-card .subtitle { font-size: 0.8125rem; color: #706e6b; text-align: center; margin-bottom: 1.5rem; }

        .signer-card {
            border: 1px solid #dddbda; border-radius: 6px; padding: 1rem; margin-bottom: 0.75rem; background: #fafafa;
        }
        .signer-card .row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .signer-card .col { flex: 1 1 45%; min-width: 200px; margin-bottom: 0.5rem; }
        .signer-card .col strong { display: block; font-size: 0.6875rem; color: #706e6b; text-transform: uppercase; margin-bottom: 2px; }
        .signer-card .col span { font-size: 0.8125rem; }
        .badge { display: inline-block; background: #0176d3; color: #fff; font-size: 0.6875rem; font-weight: 700; padding: 1px 8px; border-radius: 10px; margin-left: 4px; }
        .hash-row { font-size: 0.6875rem; color: #706e6b; word-break: break-all; margin-top: 4px; }
        .check { color: #2e844a; }

        .success-banner { background: #e8f5e1; border: 1px solid #2e844a; border-radius: 6px; padding: 1rem; margin-bottom: 1.5rem; text-align: center; }
        .success-banner h3 { color: #2e844a; margin: 0 0 0.25rem 0; font-size: 1rem; }
        .error-banner { background: #fef0ef; border: 1px solid #ea001e; border-radius: 6px; padding: 1rem; margin-bottom: 1rem; text-align: center; }
        .error-banner h3 { color: #ea001e; margin: 0 0 0.25rem 0; }

        .drop-zone {
            border: 2px dashed #0176d3; border-radius: 8px; padding: 1.5rem; text-align: center;
            cursor: pointer; position: relative; margin-top: 1.5rem; background: #f8fafc;
        }
        .drop-zone:hover { background: #eef4fb; }
        .drop-zone input { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; }
        .drop-zone p { color: #706e6b; font-size: 0.8125rem; margin: 0; }

        .spinner { display: inline-block; width: 20px; height: 20px; border: 3px solid #dddbda; border-top-color: #0176d3; border-radius: 50%; animation: spin 0.8s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
<div class="page-wrapper">
    <div class="verify-card">
        <h2>&#128737; Document Authenticator</h2>
        <p class="subtitle">Verify the authenticity of an electronically signed document.</p>

        <div id="request-results"></div>
        <div id="file-result"></div>

        <div class="drop-zone" id="drop-zone">
            <p>Drag and drop a signed PDF here, or click to browse.</p>
            <p style="font-size:0.6875rem;color:#b0adab;margin-top:4px;">The file never leaves your browser. Only the hash is verified.</p>
            <input type="file" accept=".pdf" id="file-input" />
        </div>

        <div id="processing" style="display:none;text-align:center;margin-top:1rem;">
            <div class="spinner"></div>
            <span style="margin-left:8px;font-size:0.8125rem;">Computing SHA-256 hash...</span>
        </div>
    </div>
</div>

<script>
(function() {
    // Check for request ID in URL
    var params = new URLSearchParams(window.location.search);
    var reqId = params.get('id');

    if (reqId) {
        Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.DocGenAuthenticatorController.verifyByRequestId}',
            reqId,
            function(results, event) {
                var container = document.getElementById('request-results');
                if (event.status && results && results.length > 0) {
                    var html = '<div class="success-banner"><h3>&#10003; Signature Certificate Verified</h3>';
                    html += '<p style="font-size:0.8125rem;color:#2e844a;">The following signatures were recorded for this document.</p></div>';

                    for (var i = 0; i < results.length; i++) {
                        var s = results[i];
                        html += '<div class="signer-card"><div class="row">';
                        html += '<div class="col"><strong>Signer</strong><span>' + esc(s.signerName || '');
                        if (s.roleName) html += ' <span class="badge">' + esc(s.roleName) + '</span>';
                        html += '</span></div>';
                        html += '<div class="col"><strong>Email</strong><span>' + esc(s.signerEmail || '') + '</span></div>';
                        html += '<div class="col"><strong>Signed</strong><span>' + formatDate(s.signedDate) + '</span></div>';
                        html += '<div class="col"><strong>Email Verified</strong><span>';
                        if (s.pinVerifiedAt) { html += '<span class="check">&#10003;</span> ' + formatDate(s.pinVerifiedAt); }
                        else { html += 'N/A'; }
                        html += '</span></div>';
                        html += '<div class="col"><strong>Consent</strong><span>';
                        if (s.consentCaptured) { html += '<span class="check">&#10003;</span> Granted'; }
                        else { html += 'Not recorded'; }
                        html += '</span></div>';
                        html += '<div class="col"><strong>IP Address</strong><span>' + esc(s.ipAddress || 'Unknown') + '</span></div>';
                        html += '</div>';
                        if (s.documentHash) {
                            html += '<div class="hash-row"><strong>SHA-256:</strong> ' + esc(s.documentHash) + '</div>';
                        }
                        html += '</div>';
                    }
                    container.innerHTML = html;
                } else {
                    container.innerHTML = '<div class="error-banner"><h3>No signatures found</h3><p style="font-size:0.8125rem;">No audit records found for this document ID.</p></div>';
                }
            },
            { escape: false }
        );
    }

    // File upload verification
    var dropZone = document.getElementById('drop-zone');
    var fileInput = document.getElementById('file-input');

    dropZone.addEventListener('dragover', function(e) { e.preventDefault(); });
    dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        if (e.dataTransfer.files.length > 0) processFile(e.dataTransfer.files[0]);
    });
    fileInput.addEventListener('change', function(e) {
        if (e.target.files.length > 0) processFile(e.target.files[0]);
    });

    function processFile(file) {
        document.getElementById('file-result').innerHTML = '';
        document.getElementById('processing').style.display = '';

        file.arrayBuffer().then(function(buffer) {
            return crypto.subtle.digest('SHA-256', buffer);
        }).then(function(hashBuffer) {
            var hashArray = Array.from(new Uint8Array(hashBuffer));
            var hashHex = hashArray.map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenAuthenticatorController.verifyDocument}',
                hashHex,
                function(result, event) {
                    document.getElementById('processing').style.display = 'none';
                    var container = document.getElementById('file-result');
                    if (event.status && result && result.isValid) {
                        var html = '<div class="success-banner" style="margin-top:1rem;"><h3>&#10003; ' + esc(result.message) + '</h3></div>';
                        html += '<div class="signer-card"><div class="row">';
                        html += '<div class="col"><strong>Signer</strong><span>' + esc(result.signerName) + '</span></div>';
                        html += '<div class="col"><strong>Email</strong><span>' + esc(result.signerEmail) + '</span></div>';
                        html += '<div class="col"><strong>Signed</strong><span>' + formatDate(result.signedDate) + '</span></div>';
                        html += '<div class="col"><strong>IP Address</strong><span>' + esc(result.ipAddress) + '</span></div>';
                        html += '</div>';
                        if (result.documentHash) {
                            html += '<div class="hash-row"><strong>SHA-256:</strong> ' + esc(result.documentHash) + '</div>';
                        }
                        html += '</div>';
                        container.innerHTML = html;
                    } else {
                        container.innerHTML = '<div class="error-banner" style="margin-top:1rem;"><h3>&#9888; Verification Failed</h3>' +
                            '<p style="font-size:0.8125rem;">' + esc(result ? result.message : 'Unknown error') + '</p></div>';
                    }
                },
                { escape: false }
            );
        }).catch(function(err) {
            document.getElementById('processing').style.display = 'none';
            document.getElementById('file-result').innerHTML =
                '<div class="error-banner" style="margin-top:1rem;"><h3>Error</h3><p>' + esc(err.message) + '</p></div>';
        });
    }

    function esc(s) { return s ? s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') : ''; }
    function formatDate(d) {
        if (!d) return 'N/A';
        try {
            return new Date(d).toLocaleString(undefined, {
                year: 'numeric', month: 'short', day: '2-digit',
                hour: '2-digit', minute: '2-digit', second: '2-digit',
                timeZoneName: 'short'
            });
        } catch(e) { return d; }
    }
})();
</script>
</body>
</html>
</apex:page>
